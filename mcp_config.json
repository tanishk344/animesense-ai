{
  "mcpServers": {
    "firebase-mcp-server": {
      "command": "npx",
      "args": [
        "-y",
        "firebase-tools@latest",
        "mcp"
      ],
      "env": {}
    },
    "Groq": {
      "command": "npx",
      "args": [
        "-y",
        "any-chat-completions-mcp"
      ],
      "env": {
        "API_KEY": "${GROQ_API_KEY}",
        "MODEL": "${GROQ_MODEL}",
        "BASE_URL": "${GROQ_BASE_URL}"
      }
    },
    "testsprite": {
      "command": "npx",
      "args": [
        "-y",
        "testsprite-mcp"
      ],
      "env": {}
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {}
    },
    "browser": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-browser"
      ],
      "env": {}
    }
  }
}
